# Database Configuration
DATABASE_URL=postgresql://thistory_user:dev_password@localhost:5432/thistory

# Flask Configuration
FLASK_APP=app.main:app
FLASK_ENV=development
SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# JWT Configuration
JWT_SECRET_KEY=generate-with-python-secrets-token-hex-32

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Instructions for generating secrets:
# python -c "import secrets; print(secrets.token_urlsafe(32))"  # For SECRET_KEY
# python -c "import secrets; print(secrets.token_hex(32))"      # For JWT_SECRET_KEY
